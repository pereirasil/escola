PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=escola
JWT_SECRET=chave-secreta-trocar-em-producao

# Mensalidade automática - valor padrão quando aluno não tem monthly_fee
# Dia padrão de vencimento é 10. Alunos podem ter payment_due_day e late_fee_percentage configurados.
# MONTHLY_FEE_DEFAULT=350

# Boleto bancário (Mercado Pago) - OBRIGATÓRIO para gerar boletos reais
#   1. Acesse https://www.mercadopago.com.br/developers/panel/app
#   2. Crie ou selecione uma aplicação
#   3. Em Credenciais, copie o Access Token (TEST-... para testes, APP... para produção)
#   4. Defina as credenciais abaixo (Access Token é obrigatório para boletos)
# Teste: node scripts/test-mercadopago.js
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx
# MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxx
# MERCADOPAGO_CLIENT_ID=xxxx
# MERCADOPAGO_CLIENT_SECRET=xxxx

# E-mail (SMTP) - suporta EMAIL_* ou SMTP_* (EMAIL_* tem precedência)
# Se não configurado, o envio é apenas logado no console
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=seu-email@gmail.com
# EMAIL_PASS=senha-de-app-do-google
# EMAIL_FROM="Sistema de Gestão Escolar <seu-email@gmail.com>"
# SMTP_HOST=smtp.exemplo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@escola.com

# Redis - opcional. Se não configurado, e-mails são enviados de forma síncrona (sem fila).
# Para usar fila BullMQ, defina REDIS_URL ou REDIS_HOST.
# REDIS_ENABLED=false - desabilita Redis mesmo se REDIS_URL/REDIS_HOST estiverem definidos
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379
